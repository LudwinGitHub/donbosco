generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum MatchStatus {
  SCHEDULED
  PLAYED
  CANCELLED
  POSTPONED
}

enum Role {
  ORGANIZER
  PLAYER
}

enum RegistrationStatus {
  CONFIRMED
  WAITLIST
}

enum PaymentStatus {
  UNPAID
  PAID
  EXEMPT
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          Role     @default(PLAYER)
  emailVerified Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registrations          MatchRegistration[]
  player                 Player?
  drawVotes              DrawVote[]
  pushSubscriptions      PushSubscription[]
  comments               MatchComment[]
  emailVerificationToken EmailVerificationToken?
  payments               MatchPayment[]
  mvpVotesGiven          MatchMvpVote[] @relation("mvpVoter")
  announcements          Announcement[]
  chatMessages           ChatMessage[]

  @@map("users")
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

model Player {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  nickname  String?
  photoUrl  String?
  userId    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  teamPlayers   TeamPlayer[]
  matchLineups  MatchLineup[]
  goalsScored   Goal[]        @relation("scorer")
  goalsAssisted Goal[]        @relation("assister")
  mvpMatches       Match[]        @relation("matchMvp")
  mvpVotesReceived MatchMvpVote[] @relation("mvpNominee")

  @@map("players")
}

model Season {
  id        String    @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime?
  isActive  Boolean   @default(false)
  createdAt DateTime  @default(now())

  teams   Team[]
  matches Match[]

  @@map("seasons")
}

model Team {
  id       String  @id @default(cuid())
  name     String
  color    String
  seasonId String
  season   Season  @relation(fields: [seasonId], references: [id])

  teamPlayers  TeamPlayer[]
  homeMatches  Match[]       @relation("homeTeam")
  awayMatches  Match[]       @relation("awayTeam")
  goals        Goal[]
  matchLineups MatchLineup[]

  @@map("teams")
}

// Przypisanie gracza do drużyny w sezonie
model TeamPlayer {
  playerId String
  teamId   String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([playerId, teamId])
  @@map("team_players")
}

model Match {
  id          String      @id @default(cuid())
  seasonId    String
  season      Season      @relation(fields: [seasonId], references: [id])
  homeTeamId  String
  homeTeam    Team        @relation("homeTeam", fields: [homeTeamId], references: [id])
  awayTeamId  String
  awayTeam    Team        @relation("awayTeam", fields: [awayTeamId], references: [id])
  homeScore   Int?
  awayScore   Int?
  scheduledAt DateTime
  playedAt    DateTime?
  status      MatchStatus @default(SCHEDULED)
  venue       String?
  round       Int?
  playerLimit   Int         @default(14)
  reminderSent  Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  mvpPlayerId String?
  mvpPlayer   Player?     @relation("matchMvp", fields: [mvpPlayerId], references: [id], onDelete: SetNull)

  goals         Goal[]
  matchLineups  MatchLineup[]
  registrations MatchRegistration[]
  draw          MatchDraw?
  comments      MatchComment[]
  payments      MatchPayment[]
  mvpVotes      MatchMvpVote[]

  @@map("matches")
}

model MatchRegistration {
  id        String             @id @default(cuid())
  matchId   String
  match     Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    RegistrationStatus
  createdAt DateTime           @default(now())

  @@unique([matchId, userId])
  @@map("match_registrations")
}

// Bramka – strzelec, opcjonalna asysta, minuta
model Goal {
  id         String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  teamId     String
  team       Team     @relation(fields: [teamId], references: [id])
  scorerId   String
  scorer     Player   @relation("scorer", fields: [scorerId], references: [id])
  assisterId String?
  assister   Player?  @relation("assister", fields: [assisterId], references: [id])
  minute     Int?
  isOwnGoal  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("goals")
}

model MatchDraw {
  id             String     @id @default(cuid())
  matchId        String     @unique
  match          Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  optionATeam1   String[]
  optionATeam2   String[]
  optionARating1 Float
  optionARating2 Float
  optionBTeam1   String[]
  optionBTeam2   String[]
  optionBRating1 Float
  optionBRating2 Float
  votes          DrawVote[]
  createdAt      DateTime   @default(now())

  @@map("match_draws")
}

model DrawVote {
  matchId String
  userId  String
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  draw    MatchDraw @relation(fields: [matchId], references: [matchId], onDelete: Cascade)
  choice  String

  @@id([matchId, userId])
  @@map("draw_votes")
}

model MatchComment {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())

  @@map("match_comments")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @default(cuid())
  expiresAt DateTime

  @@map("email_verification_tokens")
}

// Skład na mecz – kto faktycznie grał
model MatchLineup {
  matchId  String
  playerId String
  teamId   String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player   Player @relation(fields: [playerId], references: [id])
  team     Team   @relation(fields: [teamId], references: [id])

  @@id([matchId, playerId])
  @@map("match_lineups")
}

model MatchPayment {
  id          String        @id @default(cuid())
  matchId     String
  match       Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal       @db.Decimal(10, 2)
  status      PaymentStatus @default(UNPAID)
  paidAt      DateTime?
  paymentNote String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([matchId, userId])
  @@map("match_payments")
}

model MatchMvpVote {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  voterId   String
  voter     User     @relation("mvpVoter", fields: [voterId], references: [id], onDelete: Cascade)
  nomineeId String
  nominee   Player   @relation("mvpNominee", fields: [nomineeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([matchId, voterId])
  @@map("match_mvp_votes")
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  isPinned  Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

model ChatMessage {
  id        String   @id @default(cuid())
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("chat_messages")
}
